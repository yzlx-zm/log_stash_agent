{
  "name": "logstash",
  "version": "0.1.0",
  "type": "module",
  "description": "压测日志分析缓存文档系统 — 统一的压测日志/图片/PCAP 文件管理、搜索与文档化工具",
  "main": "dist/main.js",
  "bin": {
    "logstash": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/main.js",
    "test": "node --test dist/test/*.test.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "log-analysis",
    "stress-test",
    "pcap",
    "document-management",
    "压测",
    "日志分析"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.2",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
